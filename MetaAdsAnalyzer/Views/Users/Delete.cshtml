@model MetaAdsAnalyzer.Models.UserModel

@{
    ViewData["Title"] = "Eliminar usuario";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <span class="material-icons align-middle me-2">arrow_back</span> Volver a la lista
        </a>
    </div>

    <div class="alert alert-danger">
        <span class="material-icons align-middle me-2">warning</span>
        <strong>¿Está seguro de que desea eliminar este usuario?</strong>
        <p class="mb-0">Esta acción no se puede deshacer.</p>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Información del usuario</h5>

                    <dl class="row">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Username)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Username)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Role)</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-primary">@Html.DisplayFor(model => model.Role)</span>
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
                        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.LastLogin)</dt>
                        <dd class="col-sm-9">
                            @if (Model.LastLogin.HasValue)
                            {
                                @Model.LastLogin.Value.ToString("dd/MM/yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">Nunca ha iniciado sesión</span>
                            }
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsActive)</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <span class="material-icons align-middle me-2">delete</span> Confirmar eliminación
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <span class="material-icons align-middle me-2">cancel</span> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@model MetaAdsAnalyzer.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <span class="material-icons text-primary" style="font-size: 48px;">login</span>
                    <h2 class="mt-2">@ViewData["Title"]</h2>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Campo oculto para ReturnUrl -->
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Nombre de usuario o correo" />
                        <label asp-for="Username">Usuario o correo electrónico</label>
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control" placeholder="Contraseña" />
                        <label asp-for="Password">Contraseña</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Recordarme</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <span class="material-icons align-middle me-2">login</span> Iniciar sesión
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}